# Undersec Gateway Environment Configuration

# Database Configuration
# In production, replace with your managed PostgreSQL URL
# DATABASE_URL=postgresql://user:password@localhost:5432/undersec_db
DATABASE_URL=sqlite:///./undersec.db

# CORS Configuration
# Comma separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,chrome-extension://*

# Gemini API Key (Required for GenAI explainers)
GEMINI_API_KEY=your_gemini_api_key_here
